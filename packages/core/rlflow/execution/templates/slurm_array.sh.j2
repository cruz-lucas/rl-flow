#!/usr/bin/env bash
#SBATCH --job-name={{ sweep.sweep_id }}
#SBATCH --output={{ sweep.sweep_dir }}/logs/slurm-array-%A_%a.out
#SBATCH --error={{ sweep.sweep_dir }}/logs/slurm-array-%A_%a.err
#SBATCH --time={{ options.time }}
{% if options.nodes -%}
#SBATCH --nodes={{ options.nodes }}
{% endif -%}
{% if options.ntasks -%}
#SBATCH --ntasks={{ options.ntasks }}
{% endif -%}
#SBATCH --cpus-per-task={{ options.cpus_per_task }}
#SBATCH --mem={{ options.mem }}
#SBATCH --array=0-{{ last_index }}{% if max_parallel %}%{{ max_parallel }}{% endif %}
{% if options.partition -%}
#SBATCH --partition={{ options.partition }}
{% endif -%}
{% if options.account -%}
#SBATCH --account={{ options.account }}
{% endif -%}
{% if options.gres -%}
#SBATCH --gres={{ options.gres }}
{% endif -%}
{% if options.constraint -%}
#SBATCH --constraint={{ options.constraint }}
{% endif -%}
{% if options.qos -%}
#SBATCH --qos={{ options.qos }}
{% endif -%}
{% if options.reservation -%}
#SBATCH --reservation={{ options.reservation }}
{% endif -%}
{% if options.mail_user -%}
#SBATCH --mail-user={{ options.mail_user }}
{% endif -%}
{% if options.mail_type -%}
#SBATCH --mail-type={{ options.mail_type }}
{% endif %}
set -euo pipefail

COMMANDS=(
{% for task in tasks -%}
  {{ task.command }}
{% endfor -%}
)

RUN_DIRS=(
{% for task in tasks -%}
  {{ task.run_dir }}
{% endfor -%}
)

TASK_ID="${SLURM_ARRAY_TASK_ID:?SLURM_ARRAY_TASK_ID is required}"
export RLFLOW_BACKEND=slurm

TRIALS_PER_TASK={{ trials_per_task }}
TOTAL_TRIALS={{ total_trials }}
START_INDEX=$((TASK_ID * TRIALS_PER_TASK))
END_INDEX=$((START_INDEX + TRIALS_PER_TASK))
if (( END_INDEX > TOTAL_TRIALS )); then
  END_INDEX=$TOTAL_TRIALS
fi

{% for key, value in options.env.items() -%}
export {{ key }}="{{ value }}"
{% endfor -%}
{% for module in options.modules -%}
module load {{ module }}
{% endfor -%}
{% if options.venv_path -%}
source "{{ options.venv_path }}/bin/activate"
{% endif -%}
{% if options.conda_env -%}
conda activate "{{ options.conda_env }}"
{% endif -%}
{% for line in options.preamble -%}
{{ line }}
{% endfor %}
EXIT_CODE=0
for ((TRIAL_INDEX = START_INDEX; TRIAL_INDEX < END_INDEX; TRIAL_INDEX++)); do
  COMMAND="${COMMANDS[$TRIAL_INDEX]}"
  RUN_DIR="${RUN_DIRS[$TRIAL_INDEX]}"
  export RLFLOW_EXTERNAL_ID="${SLURM_ARRAY_JOB_ID:-${SLURM_JOB_ID:-}}_${TASK_ID}"
  if ! mkdir -p "{{ sweep.sweep_dir }}/logs" "$RUN_DIR/logs"; then
    EXIT_CODE=1
    continue
  fi
  if ! cd "$RUN_DIR"; then
    EXIT_CODE=1
    continue
  fi
  if ! bash "$COMMAND"; then
    EXIT_CODE=1
  fi
done

exit "$EXIT_CODE"
